<div class="container-fluid pb-0" id="main-page-container" style="zoom: 0.85;">
    <!-- Header Page -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="fw-bold text-dark mb-1"><i class="bi bi-display me-2 text-primary"></i>Monitoring Absensi</h4>
            <p class="text-muted small mb-0">Daftar kehadiran karyawan harian.</p>
        </div>
        <div class="d-flex gap-2">
            <div class="input-group input-group-sm" style="width: 280px;">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="searchInput" class="form-control border-start-0 ps-0" placeholder="Cari nama atau cabang..." onkeyup="filterTable()">
            </div>
            <button class="btn btn-sm btn-outline-primary" onclick="fetchInitialData()">
                <i class="bi bi-arrow-clockwise"></i> Refresh
            </button>
        </div>
    </div>

    <!-- Main Card -->
    <div class="card border-0 shadow-sm mb-0" style="overflow: hidden;">
        <div class="card-body p-0">
            <!-- Loading Spinner -->
            <div id="loader" class="text-center py-5">
                <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-3 text-secondary fw-medium">Memuat data absensi...</p>
            </div>

            <!-- Table Container -->
            <div class="table-responsive" id="tableContainer" style="display: none;">
                <table class="table table-hover align-middle mb-0" id="attendanceTable">
                    <thead>
                    <tr>
                        <th class="ps-4 py-3 border-0 text-secondary small text-uppercase">Tanggal</th>
                        <th class="py-3 border-0 text-secondary small text-uppercase">Nama Karyawan</th>
                        <th class="py-3 border-0 text-secondary small text-uppercase">Cabang</th>
                        <th class="py-3 border-0 text-secondary small text-uppercase">Waktu Masuk</th>
                        <th class="text-center pe-4 py-3 border-0 text-secondary small text-uppercase">Aksi</th>
                    </tr>
                    </thead>
                    <tbody id="attendanceTableBody">
                    <!-- Data rows will be injected by JavaScript -->
                    </tbody>
                </table>
            </div>

            <!-- Empty State -->
            <div id="emptyState" class="text-center py-5" style="display: none;">
                <i class="bi bi-calendar-x fs-1 text-muted"></i>
                <p class="mt-2 text-muted">Tidak ada data absensi ditemukan.</p>
            </div>
        </div>
    </div>
</div>

<!-- Modal Edit Absensi -->
<div class="modal fade" id="editAttendanceModal" tabindex="-1" aria-labelledby="editAttendanceModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white py-3">
                <h5 class="modal-title fw-bold" id="editAttendanceModalLabel">
                    <i class="bi bi-pencil-square me-2"></i>Edit Absensi
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editAttendanceForm">
                <div class="modal-body p-4">
                    <input type="hidden" id="edit_row">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Tanggal</label>
                        <input type="date" id="edit_tanggal" class="form-control form-control-sm" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Nama Karyawan</label>
                        <input type="text" id="edit_nama" class="form-control form-control-sm" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Cabang</label>
                        <input type="text" id="edit_cabang" class="form-control form-control-sm" readonly>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Status Kehadiran</label>
                        <select id="edit_status_hadir" class="form-select form-select-sm" onchange="toggleTimeInput()">
                            <option value="HADIR">HADIR (Input Jam)</option>
                            <option value="OFF">OFF</option>
                            <option value="SAKIT">SAKIT</option>
                            <option value="IZIN">IZIN</option>
                            <option value="ALPA">ALPA</option>
                        </select>
                    </div>

                    <div class="mb-3" id="time_input_container">
                        <label class="form-label small fw-bold">Waktu Masuk</label>
                        <input type="time" id="edit_waktu" class="form-control form-control-sm">
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Batal</button>
                    <button type="submit" class="btn btn-sm btn-primary px-4" id="btnSaveAttendance">
                        <span id="btnSaveAttendanceText">Simpan Perubahan</span>
                        <span id="btnSaveAttendanceLoader" class="spinner-border spinner-border-sm d-none"></span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

{{include:2_Absensi_Monitoring_JS}}
